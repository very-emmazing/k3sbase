#!/usr/bin/env bash
#MISE description="Cluster erstellen (local → k3d, pi → k3s via SSH) und Kubeconfig schreiben"
set -euo pipefail

CLUSTER="${1:?Fehler: Cluster angeben – z.B.: mise run cluster-up -- local}"
REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

case "${CLUSTER}" in
  local|pi) ;;
  *) printf "Unbekannter Cluster '%s'. Erlaubt: local | pi\n" "${CLUSTER}" >&2; exit 1 ;;
esac

# ── Local (k3d) ───────────────────────────────────────────────────────────────
if [[ "${CLUSTER}" == "local" ]]; then
  if k3d cluster list 2>/dev/null | awk 'NR>1 {print $1}' | grep -qx "${CLUSTER}"; then
    echo "k3d cluster '${CLUSTER}' already exists, skipping"
  else
    # --agents 2               : 1 Server + 2 Agents, näher an der Pi-Topologie
    # --flannel-backend=none   : Cilium liefert das Datplane
    # --disable-kube-proxy     : Cilium ersetzt kube-proxy vollständig (eBPF)
    # --disable-network-policy : Cilium übernimmt NetworkPolicies
    # --no-lb                  : kein k3d-LoadBalancer-Container für lokale Dev
    k3d cluster create "${CLUSTER}" \
      --agents 2 \
      --k3s-arg '--disable=traefik@server:*' \
      --k3s-arg '--disable=servicelb@server:*' \
      --k3s-arg '--disable=local-storage@server:*' \
      --k3s-arg '--flannel-backend=none@server:*' \
      --k3s-arg '--disable-network-policy@server:*' \
      --k3s-arg '--disable-kube-proxy@server:*' \
      --no-lb \
      --wait
    echo "k3d cluster '${CLUSTER}' erstellt"
  fi

  mkdir -p "${REPO_ROOT}/.kube"
  k3d kubeconfig get "${CLUSTER}" > "${REPO_ROOT}/.kube/config"
  chmod 600 "${REPO_ROOT}/.kube/config"
  echo "Kubeconfig: ${REPO_ROOT}/.kube/config"

  # ── Cilium HelmRelease patchen ───────────────────────────────────────────────
  # Docker-Hostname ("k3d-local-server-0") ist nur vom Server-Node selbst auflösbar;
  # von anderen Nodes (z.B. zusätzliche Agents) scheitert die Pod-DNS-Auflösung.
  # Daher die konkrete Container-IP im Docker-Netzwerk verwenden.
  # Immer mit der aktuellen IP abgleichen – nicht nur beim ersten Mal (Platzhalter):
  # Docker vergibt IPs nicht deterministisch, nach cluster delete + create kann
  # die Server-IP abweichen und ein alter Wert im Manifest wäre sonst stale.
  CILIUM_MANIFEST="${REPO_ROOT}/clusters/local/infrastructure/cilium.yaml"
  SERVER_IP="$(docker inspect -f "{{ (index .NetworkSettings.Networks \"k3d-${CLUSTER}\").IPAddress }}" "k3d-${CLUSTER}-server-0")"
  [[ -n "${SERVER_IP}" ]] || { echo "Fehler: IP von k3d-${CLUSTER}-server-0 nicht ermittelbar"; exit 1; }
  CURRENT_HOST="$(grep -oE 'k8sServiceHost: "[^"]*"' "${CILIUM_MANIFEST}" | cut -d'"' -f2)"
  if [[ "${CURRENT_HOST}" != "${SERVER_IP}" ]]; then
    TMP_FILE="$(mktemp)"
    sed "s|k8sServiceHost: \"[^\"]*\"|k8sServiceHost: \"${SERVER_IP}\"|" "${CILIUM_MANIFEST}" > "${TMP_FILE}" && mv "${TMP_FILE}" "${CILIUM_MANIFEST}"
    echo
    echo "  cilium.yaml aktualisiert (k8sServiceHost: ${CURRENT_HOST:-<leer>} → ${SERVER_IP})"
    echo "  Bitte vor cilium-up committen und pushen (Flux reconciliert origin/main):"
    echo "    git add clusters/local/infrastructure/cilium.yaml"
    echo "    git commit -m 'chore(local): set cilium api server host'"
    echo "    git push"
  fi

  printf "\nWeiter mit:\n"
  printf "  mise run cilium-up     -- %s\n" "${CLUSTER}"
  printf "  mise run flux-bootstrap -- %s\n" "${CLUSTER}"
fi

# ── Pi (k3s via SSH) ──────────────────────────────────────────────────────────
if [[ "${CLUSTER}" == "pi" ]]; then
  NODES_ENV="${REPO_ROOT}/clusters/pi/nodes.env"
  VERSIONS_ENV="${REPO_ROOT}/clusters/pi/versions.env"
  CILIUM_MANIFEST="${REPO_ROOT}/clusters/pi/infrastructure/cilium.yaml"
  PI_KUBECONFIG="${REPO_ROOT}/.kube/pi-config"

  [[ -f "${NODES_ENV}" ]]    || { echo "Fehler: ${NODES_ENV} fehlt – zuerst: mise run setup -- pi"; exit 1; }
  [[ -f "${VERSIONS_ENV}" ]] || { echo "Fehler: ${VERSIONS_ENV} fehlt – zuerst: mise run setup -- pi"; exit 1; }
  # shellcheck source=/dev/null
  source "${NODES_ENV}"
  # shellcheck source=/dev/null
  source "${VERSIONS_ENV}"

  for var in PI_USER PI_SERVER PI_AGENT_0 PI_AGENT_1 PI_AGENT_2; do
    [[ -z "${!var:-}" ]] && { echo "Fehler: ${var} ist leer in ${NODES_ENV}"; exit 1; }
  done

  ALL_NODES=("${PI_SERVER}" "${PI_AGENT_0}" "${PI_AGENT_1}" "${PI_AGENT_2}")
  AGENTS=("${PI_AGENT_0}" "${PI_AGENT_1}" "${PI_AGENT_2}")

  ssh_do() {
    local node="$1"; shift
    ssh -o StrictHostKeyChecking=accept-new -o ConnectTimeout=10 \
        -o BatchMode=yes "${PI_USER}@${node}" "$@"
  }

  echo "Nodes: server=${PI_SERVER}  agents=${PI_AGENT_0} ${PI_AGENT_1} ${PI_AGENT_2}"
  echo

  # ── [1/4] Chrony (NTP) ──────────────────────────────────────────────────────
  echo "=== [1/4] Chrony auf allen Nodes ==="
  # Chrony ist essenziell: stark abweichende Uhren führen zu TLS-Fehlern zwischen Nodes.
  for node in "${ALL_NODES[@]}"; do
    printf "  %-18s " "${node}"
    if ssh_do "${node}" "chronyc tracking &>/dev/null"; then
      echo "bereits aktiv"
    else
      ssh_do "${node}" "
        sudo apt-get update -qq -o=Dpkg::Use-Pty=0 &&
        sudo apt-get install -y -q chrony &&
        sudo systemctl enable --now chrony
      " >/dev/null
      echo "installiert"
    fi
  done

  # ── [2/4] k3s Server ────────────────────────────────────────────────────────
  echo
  echo "=== [2/4] k3s Server (${PI_SERVER}) ==="
  if ssh_do "${PI_SERVER}" "command -v k3s &>/dev/null"; then
    echo "  k3s bereits installiert – übersprungen"
  else
    ssh_do "${PI_SERVER}" "
      curl -sfL https://get.k3s.io | INSTALL_K3S_VERSION=\"${K3S_VERSION}\" sh -s - server \
        --disable traefik \
        --disable servicelb \
        --disable local-storage \
        --flannel-backend=none \
        --disable-network-policy \
        --disable-kube-proxy \
        --tls-san \"${PI_SERVER}\"
    "
    # Kein Ready-Wait: ohne CNI (flannel-backend=none) bleiben Nodes NotReady
    # bis cilium-up gelaufen ist – Ready-Warten wäre ein garantierter Timeout.
    # Stattdessen nur warten bis der API-Server antwortet und der Node registriert ist.
    echo "  Warte bis API-Server erreichbar und Node registriert …"
    ssh_do "${PI_SERVER}" "
      for _ in \$(seq 1 60); do
        sudo k3s kubectl get nodes --no-headers 2>/dev/null | grep -q . && exit 0
        sleep 2
      done
      echo 'Timeout: k3s API nicht erreichbar oder Node nicht registriert' >&2
      exit 1
    " >/dev/null
    echo "  Registriert"
  fi

  K3S_TOKEN="$(ssh_do "${PI_SERVER}" "sudo cat /var/lib/rancher/k3s/server/node-token")"

  # ── [3/4] k3s Agents ────────────────────────────────────────────────────────
  echo
  echo "=== [3/4] k3s Agents ==="
  AGENTS_INSTALLED=false
  for agent in "${AGENTS[@]}"; do
    printf "  %-18s " "${agent}"
    if ssh_do "${agent}" "command -v k3s &>/dev/null"; then
      echo "bereits installiert"
    else
      # Token via stdin statt auf der Remote-Kommandozeile (sonst in ps sichtbar).
      printf '%s' "${K3S_TOKEN}" | ssh_do "${agent}" "
        K3S_TOKEN=\"\$(cat)\"
        export K3S_TOKEN
        curl -sfL https://get.k3s.io | \
          INSTALL_K3S_VERSION=\"${K3S_VERSION}\" \
          K3S_URL=\"https://${PI_SERVER}:6443\" \
          sh -
      " >/dev/null
      echo "installiert"
      AGENTS_INSTALLED=true
    fi
  done

  if [[ "${AGENTS_INSTALLED}" == true ]]; then
    # Wie beim Server: Ready kommt erst mit dem CNI, hier nur Registrierung prüfen.
    echo "  Warte bis alle ${#ALL_NODES[@]} Nodes registriert sind …"
    ssh_do "${PI_SERVER}" "
      for _ in \$(seq 1 90); do
        [ \"\$(sudo k3s kubectl get nodes --no-headers 2>/dev/null | wc -l)\" -ge ${#ALL_NODES[@]} ] && exit 0
        sleep 2
      done
      echo 'Timeout: nicht alle Nodes registriert' >&2
      exit 1
    " >/dev/null
    echo "  Alle Nodes registriert"
  fi

  # ── [4/4] Kubeconfig exportieren ────────────────────────────────────────────
  echo
  echo "=== [4/4] Kubeconfig ==="
  mkdir -p "${REPO_ROOT}/.kube"
  ssh_do "${PI_SERVER}" "sudo cat /etc/rancher/k3s/k3s.yaml" \
    | sed "s|https://127.0.0.1:6443|https://${PI_SERVER}:6443|" \
    > "${PI_KUBECONFIG}"
  chmod 600 "${PI_KUBECONFIG}"
  echo "  Geschrieben: ${PI_KUBECONFIG}"

  # ── Cilium HelmRelease patchen ───────────────────────────────────────────────
  # Immer mit PI_SERVER abgleichen (nicht nur Platzhalter ersetzen), damit eine
  # geänderte Server-IP in nodes.env nicht stale im Manifest zurückbleibt.
  CURRENT_HOST="$(grep -oE 'k8sServiceHost: "[^"]*"' "${CILIUM_MANIFEST}" | cut -d'"' -f2)"
  if [[ "${CURRENT_HOST}" != "${PI_SERVER}" ]]; then
    TMP_FILE="$(mktemp)"
    sed "s|k8sServiceHost: \"[^\"]*\"|k8sServiceHost: \"${PI_SERVER}\"|" "${CILIUM_MANIFEST}" > "${TMP_FILE}" && mv "${TMP_FILE}" "${CILIUM_MANIFEST}"
    echo
    echo "  cilium.yaml aktualisiert (k8sServiceHost: ${CURRENT_HOST:-<leer>} → ${PI_SERVER})"
    echo "  Bitte vor cilium-up committen und pushen (Flux reconciliert origin/main):"
    echo "    git add clusters/pi/infrastructure/cilium.yaml"
    echo "    git commit -m 'chore(pi): set cilium api server host'"
    echo "    git push"
  fi

  printf "\nWeiter mit:\n"
  printf "  git add clusters/pi/infrastructure/cilium.yaml && git commit -m 'chore(pi): set cilium api server host' && git push\n"
  printf "  mise run cilium-up      -- %s\n" "${CLUSTER}"
  printf "  mise run flux-bootstrap  -- %s\n" "${CLUSTER}"
fi
