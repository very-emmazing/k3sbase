#!/usr/bin/env bash
#MISE description="Flux Operator + FluxInstance + SOPS-age-Secret installieren"
# Voraussetzung: Cilium läuft (mise run cilium-up -- <cluster>)
set -euo pipefail

CLUSTER="${1:?Fehler: Cluster angeben – z.B.: mise run flux-bootstrap -- local}"
REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
AGE_KEY_FILE="${HOME}/.config/sops/age/keys.txt"

case "${CLUSTER}" in
  local|pi) ;;
  *) printf "Unbekannter Cluster '%s'. Erlaubt: local | pi\n" "${CLUSTER}" >&2; exit 1 ;;
esac

VERSIONS_CM="${REPO_ROOT}/clusters/${CLUSTER}/cluster-versions.yaml"
[[ -f "${VERSIONS_CM}" ]] || { echo "Fehler: ${VERSIONS_CM} fehlt"; exit 1; }
FLUX_OPERATOR_VERSION="$(grep -E '^  FLUX_OPERATOR_VERSION:' "${VERSIONS_CM}" | awk '{print $2}' | tr -d '"')"
[[ -n "${FLUX_OPERATOR_VERSION}" ]] || { echo "Fehler: FLUX_OPERATOR_VERSION fehlt in ${VERSIONS_CM}"; exit 1; }

if [[ "${CLUSTER}" == "local" ]]; then
  export KUBECONFIG="${REPO_ROOT}/.kube/config"
  [[ -f "${KUBECONFIG}" ]] || { echo "Fehler: ${KUBECONFIG} fehlt – zuerst: mise run cluster-up -- local"; exit 1; }
fi

if [[ "${CLUSTER}" == "pi" ]]; then
  export KUBECONFIG="${REPO_ROOT}/.kube/pi-config"
  [[ -f "${KUBECONFIG}" ]] || { echo "Fehler: ${KUBECONFIG} fehlt – zuerst: mise run cluster-up -- pi"; exit 1; }
fi

# ── cilium.yaml muss gesetzt UND auf origin/main sein ─────────────────────────
# Flux reconciliert origin/main, nicht den lokalen Checkout: ein nur lokal
# committeter (oder gar uncommitteter) k8sServiceHost käme im Cluster nie an.
CILIUM_REL="clusters/${CLUSTER}/infrastructure/cilium.yaml"
if grep -q 'REPLACE_WITH_' "${REPO_ROOT}/${CILIUM_REL}"; then
  echo "Fehler: k8sServiceHost in ${CILIUM_REL} noch nicht gesetzt."
  echo "  mise run cluster-up -- ${CLUSTER} ausführen, dann committen und pushen."
  exit 1
fi
if git -C "${REPO_ROOT}" rev-parse --verify -q origin/main >/dev/null; then
  git -C "${REPO_ROOT}" fetch -q origin main 2>/dev/null \
    || echo "Warnung: git fetch fehlgeschlagen – prüfe gegen letzten bekannten Stand von origin/main"
  if ! git -C "${REPO_ROOT}" diff --quiet origin/main -- "${CILIUM_REL}"; then
    echo "Fehler: ${CILIUM_REL} weicht von origin/main ab."
    echo "  Flux reconciliert origin/main – Änderung committen und pushen:"
    echo "    git add ${CILIUM_REL} && git commit -m 'chore(${CLUSTER}): set cilium api server host' && git push"
    exit 1
  fi
else
  echo "Warnung: kein origin/main gefunden – Push-Check übersprungen"
fi

[[ -f "${AGE_KEY_FILE}" ]] || { echo "Fehler: age-Key fehlt – zuerst: mise run setup -- ${CLUSTER}"; exit 1; }

# ── Flux Operator ──────────────────────────────────────────────────────────────
# Imperativ einmalig installiert; danach selbst-verwaltet über die FluxInstance.
if helm status flux-operator -n flux-system &>/dev/null; then
  echo "Flux Operator bereits installiert – übersprungen"
else
  helm upgrade --install flux-operator \
    oci://ghcr.io/controlplaneio-fluxcd/charts/flux-operator \
    --version "${FLUX_OPERATOR_VERSION}" \
    --namespace flux-system \
    --create-namespace \
    --wait
fi

# ── FluxInstance ───────────────────────────────────────────────────────────────
kubectl apply -f "${REPO_ROOT}/clusters/${CLUSTER}/flux-system/flux-instance.yaml"

# ── SOPS age Secret ───────────────────────────────────────────────────────────
kubectl create secret generic sops-age \
  --namespace flux-system \
  --from-file=age.agekey="${AGE_KEY_FILE}" \
  --dry-run=client -o yaml | kubectl apply -f -

echo
echo "Flux Bootstrap abgeschlossen."
echo "Flux reconciliert jetzt clusters/${CLUSTER}/ aus dem Repo."
