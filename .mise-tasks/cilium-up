#!/usr/bin/env bash
#MISE description="Cilium imperativ installieren (muss vor flux-bootstrap laufen)"
# Ohne CNI bleiben alle Pods Pending – auch Flux selbst.
# Nach dem Bootstrap übernimmt Flux die HelmRelease per Adoption
# (gleicher Release-Name "cilium" im Namespace "kube-system").
set -euo pipefail

CLUSTER="${1:?Fehler: Cluster angeben – z.B.: mise run cilium-up -- local}"
REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

case "${CLUSTER}" in
  local|pi) ;;
  *) printf "Unbekannter Cluster '%s'. Erlaubt: local | pi\n" "${CLUSTER}" >&2; exit 1 ;;
esac

if [[ "${CLUSTER}" == "local" ]]; then
  export KUBECONFIG="${REPO_ROOT}/.kube/config"
  [[ -f "${KUBECONFIG}" ]] || { echo "Fehler: ${KUBECONFIG} fehlt – zuerst: mise run cluster-up -- local"; exit 1; }

  # k8sServiceHost wird aus der HelmRelease gelesen (single source of truth,
  # von "mise run cluster-up -- local" mit der Server-Container-IP gepatcht).
  CILIUM_MANIFEST="${REPO_ROOT}/clusters/local/infrastructure/cilium.yaml"
  if grep -q 'REPLACE_WITH_LOCAL_SERVER_IP' "${CILIUM_MANIFEST}"; then
    echo "Fehler: k8sServiceHost in ${CILIUM_MANIFEST} noch nicht gesetzt."
    echo "  mise run cluster-up -- local ausführen und cilium.yaml danach committen."
    exit 1
  fi
  SERVER_IP="$(grep -oE 'k8sServiceHost: "[^"]+"' "${CILIUM_MANIFEST}" | cut -d'"' -f2)"
  [[ -n "${SERVER_IP}" ]] || { echo "Fehler: k8sServiceHost nicht gefunden in ${CILIUM_MANIFEST}"; exit 1; }

  if cilium status &>/dev/null; then
    echo "Cilium bereits installiert – übersprungen"
  else
    cilium install \
      --set kubeProxyReplacement=true \
      --set k8sServiceHost="${SERVER_IP}" \
      --set k8sServicePort=6443

    cilium status --wait
    echo "Cilium bereit"
  fi
fi

if [[ "${CLUSTER}" == "pi" ]]; then
  export KUBECONFIG="${REPO_ROOT}/.kube/pi-config"
  [[ -f "${KUBECONFIG}" ]] || { echo "Fehler: ${KUBECONFIG} fehlt – zuerst: mise run cluster-up -- pi"; exit 1; }

  # shellcheck source=/dev/null
  source "${REPO_ROOT}/clusters/pi/nodes.env"
  [[ -z "${PI_SERVER:-}" ]] && { echo "Fehler: PI_SERVER nicht gesetzt in clusters/pi/nodes.env"; exit 1; }

  if cilium status &>/dev/null; then
    echo "Cilium bereits installiert – übersprungen"
  else
    cilium install \
      --set kubeProxyReplacement=true \
      --set k8sServiceHost="${PI_SERVER}" \
      --set k8sServicePort=6443

    cilium status --wait
    echo "Cilium bereit"
  fi
fi
