#!/usr/bin/env bash
#MISE description="Interaktiver Setup-Assistent: age-Key, SOPS-Recipient, Secrets abfragen und verschlüsseln"
set -euo pipefail

CLUSTER="${1:?Fehler: Cluster angeben – z.B.: mise run setup -- local}"
REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
AGE_KEY_FILE="${HOME}/.config/sops/age/keys.txt"
SOPS_YAML="${REPO_ROOT}/.sops.yaml"

case "${CLUSTER}" in
  local|pi) ;;
  *) printf "Unbekannter Cluster '%s'. Erlaubt: local | pi\n" "${CLUSTER}" >&2; exit 1 ;;
esac

TOTAL=3; [[ "${CLUSTER}" == "pi" ]] && TOTAL=4
STEP=0

if [[ -t 1 ]]; then
  GRN='\033[0;32m' YEL='\033[1;33m' BLU='\033[0;34m' BOLD='\033[1m' RST='\033[0m'
else
  GRN='' YEL='' BLU='' BOLD='' RST=''
fi

ok()   { printf "  ${GRN}✓${RST}  %s\n" "$*"; }
hint() { printf "  ${BLU}→${RST}  %s\n" "$*"; }
warn() { printf "  ${YEL}!${RST}  %s\n" "$*"; }
step() { STEP=$((STEP+1)); printf "\n${BOLD}[%s/%s] %s${RST}\n" "${STEP}" "${TOTAL}" "$1"; }
die()  { printf "\n${YEL}Abbruch: %s${RST}\n" "$*" >&2; exit 1; }

for tool in age-keygen sops; do
  command -v "${tool}" &>/dev/null || die "${tool} nicht gefunden – zuerst: mise install"
done

printf "\n${BOLD}════ k3sbase · Setup [%s] ════════════════${RST}\n" "${CLUSTER}"

# ── [1] age-Schlüssel ─────────────────────────────────────────────────────────
SOPS_YAML_UPDATED=false
step "age-Schlüssel"

if [[ -f "${AGE_KEY_FILE}" ]]; then
  ok "Vorhanden: ${AGE_KEY_FILE}"
else
  hint "Wird lokal generiert – verlässt diese Maschine nicht (niemals ins Repo)"
  mkdir -p "$(dirname "${AGE_KEY_FILE}")"
  age-keygen -o "${AGE_KEY_FILE}"
  chmod 600 "${AGE_KEY_FILE}"
  ok "Generiert: ${AGE_KEY_FILE}"
fi

AGE_PUB="$(grep '^# public key:' "${AGE_KEY_FILE}" | awk '{print $NF}')"
hint "Public Key: ${AGE_PUB}"

# ── [2] .sops.yaml Recipient ──────────────────────────────────────────────────
step "SOPS-Konfiguration (.sops.yaml)"

CURRENT_RCP="$(grep -E '^\s+age:' "${SOPS_YAML}" | awk '{print $2}' | tr -d '"' | head -1 || true)"
if [[ "${CURRENT_RCP}" == "${AGE_PUB}" ]]; then
  ok "Recipient stimmt überein"
else
  [[ -n "${CURRENT_RCP}" ]] && warn "Recipient unterscheidet sich – wird ersetzt (bereits verschlüsselte Secrets neu verschlüsseln!)"
  cat > "${SOPS_YAML}" <<SOPS
# Never commit the age private key (${AGE_KEY_FILE}).
creation_rules:
  - path_regex: clusters/.*\.yaml$
    age: ${AGE_PUB}
SOPS
  ok ".sops.yaml aktualisiert"
  SOPS_YAML_UPDATED=true
fi

# ── [3] Pi-Node-Konfiguration (nur pi) ───────────────────────────────────────
NODES_ENV_UPDATED=false
if [[ "${CLUSTER}" == "pi" ]]; then
  step "Pi-Node-Konfiguration (clusters/pi/nodes.env)"
  NODES_ENV="${REPO_ROOT}/clusters/pi/nodes.env"

  _nodes_ok() {
    # shellcheck source=/dev/null
    source "${NODES_ENV}" 2>/dev/null || return 1
    [[ -n "${PI_SERVER:-}" && -n "${PI_AGENT_0:-}" && -n "${PI_AGENT_1:-}" && -n "${PI_AGENT_2:-}" ]]
  }

  if _nodes_ok; then
    # _nodes_ok runs in a subshell; source again here to export vars into this shell.
    # shellcheck source=/dev/null
    source "${NODES_ENV}"
    ok "Bereits konfiguriert: server=${PI_SERVER}  agents=${PI_AGENT_0} ${PI_AGENT_1} ${PI_AGENT_2}"
  else
    hint "Voraussetzung: Ubuntu auf allen Nodes, SSH-Pubkey bereits hinterlegt"
    echo
    read -r -p "  SSH-User    [ubuntu]: " INPUT_USER
    PI_USER="${INPUT_USER:-ubuntu}"
    read -r -p "  Server-IP    (1x): "   PI_SERVER
    read -r -p "  Agent-IP 1   (1x): "   PI_AGENT_0
    read -r -p "  Agent-IP 2   (2x): "   PI_AGENT_1
    read -r -p "  Agent-IP 3   (3x): "   PI_AGENT_2
    [[ -z "${PI_SERVER}" ]] && die "Server-IP darf nicht leer sein"
    for v in PI_AGENT_0 PI_AGENT_1 PI_AGENT_2; do [[ -z "${!v}" ]] && die "${v} darf nicht leer sein"; done
    cat > "${NODES_ENV}" <<ENV
# Pi-Cluster Node-Konfiguration – generiert von: mise run setup -- pi
PI_USER="${PI_USER}"
PI_SERVER="${PI_SERVER}"
PI_AGENT_0="${PI_AGENT_0}"
PI_AGENT_1="${PI_AGENT_1}"
PI_AGENT_2="${PI_AGENT_2}"
ENV
    ok "nodes.env gesetzt"
    NODES_ENV_UPDATED=true
  fi
fi

# ── [3/4] Cloudflare API Token ────────────────────────────────────────────────
CF_SECRET="clusters/${CLUSTER}/infrastructure/external-dns-secret.yaml"
CF_SECRET_UPDATED=false

step "Cloudflare API Token (external-dns)"

if grep -q 'ENC\[' "${REPO_ROOT}/${CF_SECRET}" 2>/dev/null; then
  ok "Bereits SOPS-verschlüsselt – übersprungen"
else
  EXISTING="$(grep 'token:' "${REPO_ROOT}/${CF_SECRET}" | awk '{print $2}' | tr -d '"' | xargs 2>/dev/null || true)"
  if [[ -z "${EXISTING}" ]]; then
    hint "Token erstellen unter: https://dash.cloudflare.com/profile/api-tokens"
    hint "  → \"Create Token\" → Template \"Edit zone DNS\""
    hint "  Berechtigungen: Zone:DNS:Edit  (Zone:Zone:Read optional für Autodiscovery)"
    echo
    read -r -s -p "  Token (Eingabe unsichtbar): " CF_TOKEN
    echo
    [[ -z "${CF_TOKEN}" ]] && die "Kein Token eingegeben"
  else
    warn "Plaintext-Token gefunden – wird direkt verschlüsselt"
    CF_TOKEN="${EXISTING}"
  fi
  # Plaintext nie in die getrackte Datei schreiben: schlüge sops fehl, läge der
  # Token sonst unverschlüsselt im Repo (ein "git add ." vom Leak entfernt).
  # --filename-override lässt die creation_rules aus .sops.yaml trotz Tempfile
  # auf den Zielpfad matchen.
  TMP_SECRET="$(mktemp)"
  trap 'rm -f "${TMP_SECRET}" "${TMP_SECRET}.enc"' EXIT
  cat > "${TMP_SECRET}" <<YAML
apiVersion: v1
kind: Secret
metadata:
  name: cloudflare-api-token
  namespace: external-dns
stringData:
  token: "${CF_TOKEN}"
YAML
  SOPS_AGE_KEY_FILE="${AGE_KEY_FILE}" sops -e --filename-override "${CF_SECRET}" \
    "${TMP_SECRET}" > "${TMP_SECRET}.enc"
  mv "${TMP_SECRET}.enc" "${REPO_ROOT}/${CF_SECRET}"
  rm -f "${TMP_SECRET}"
  ok "Verschlüsselt: ${CF_SECRET}"
  CF_SECRET_UPDATED=true
fi

# ── Commits ───────────────────────────────────────────────────────────────────
_commit() {
  local msg="$1"; shift
  git -C "${REPO_ROOT}" add "$@"
  git -C "${REPO_ROOT}" commit -m "${msg}"
  ok "Committed: ${msg}"
}

HAS_CHANGES=false
[[ "${SOPS_YAML_UPDATED}" == true ]] && HAS_CHANGES=true
[[ "${NODES_ENV_UPDATED}" == true ]] && HAS_CHANGES=true
[[ "${CF_SECRET_UPDATED}" == true ]] && HAS_CHANGES=true

if [[ "${HAS_CHANGES}" == true ]]; then
  printf "\n"
  read -r -p "  Änderungen jetzt committen? (j/N) " REPLY
  if [[ "${REPLY}" =~ ^[jJ]$ ]]; then
    [[ "${SOPS_YAML_UPDATED}" == true ]] && _commit "chore(sops): set age recipient"                  .sops.yaml
    [[ "${NODES_ENV_UPDATED}" == true ]] && _commit "chore(pi): set node ips in nodes.env"            clusters/pi/nodes.env
    [[ "${CF_SECRET_UPDATED}" == true ]] && _commit "feat(${CLUSTER}): add sops-encrypted cloudflare api token" "${CF_SECRET}"
  else
    printf "\n"; hint "Manuell committen:"
    [[ "${SOPS_YAML_UPDATED}" == true ]] && hint "  git add .sops.yaml && git commit -m 'chore(sops): set age recipient'"
    [[ "${NODES_ENV_UPDATED}" == true ]] && hint "  git add clusters/pi/nodes.env && git commit -m 'chore(pi): set node ips in nodes.env'"
    [[ "${CF_SECRET_UPDATED}" == true ]] && hint "  git add ${CF_SECRET} && git commit -m 'feat(${CLUSTER}): add sops-encrypted cloudflare api token'"
  fi
fi

printf "\n${BOLD}════ Abgeschlossen ════════════════════════════${RST}\n\n"
hint "Weiter:"
hint "  mise run cluster-up    -- ${CLUSTER}"
hint "  mise run cilium-up     -- ${CLUSTER}"
hint "  mise run flux-bootstrap -- ${CLUSTER}"
printf "\n"
