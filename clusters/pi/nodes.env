# Pi-Cluster Node-Konfiguration – generiert von: mise run setup -- pi
# Leer lassen; mise run setup -- pi füllt die Werte interaktiv aus und commitet sie.
#
# Voraussetzungen:
#   - Ubuntu auf allen Nodes (kein weiteres Setup nötig)
#   - SSH-Pubkey bereits hinterlegt (ssh-copy-id)
#   - Nodes per SSH erreichbar

PI_USER="ubuntu"

PI_SERVER=""     # Server-Node (1x) – z.B. 192.168.1.10
PI_AGENT_0=""    # Agent-Node  (1x) – z.B. 192.168.1.11
PI_AGENT_1=""    # Agent-Node  (2x) – z.B. 192.168.1.12
PI_AGENT_2=""    # Agent-Node  (3x) – z.B. 192.168.1.13
