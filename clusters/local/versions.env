# Component versions for the local (k3d) cluster.
# This is the single source of truth for all pinned versions:
#   - Helm chart versions are injected into HelmReleases via Flux postBuild substitution.
#   - FLUX_OPERATOR_VERSION is read by scripts/flux-bootstrap.sh.
# The Flux distribution version lives in flux-system/flux-instance.yaml.
FLUX_OPERATOR_VERSION=0.52.0
CILIUM_VERSION=1.16.5
CERT_MANAGER_VERSION=v1.16.3
EXTERNAL_DNS_VERSION=1.15.0
